---
import FictionPage from '@/templates/FictionPage.astro';
import { getCommissionImages } from '@/utils/commissions';

const images = getCommissionImages();
---

<FictionPage
  title='Commissions | My Homepage'
  description='Commission gallery.'
>
  <section class='mx-auto max-w-[92rem] px-4 py-24 sm:px-6 lg:px-8'>
    <p
      data-page-i18n='commissions.kicker'
      class='mb-6 text-base font-black uppercase tracking-[0.28em] text-fiction-gold md:text-lg'
    >
      Commissions
    </p>
    <h1
      data-page-i18n='commissions.heading'
      class='font-fiction text-4xl font-black leading-none tracking-[-0.05em] text-fiction-ink md:text-6xl'
    >
      Commissions
    </h1>
    <p
      data-page-i18n='commissions.description'
      data-page-i18n-html
      class='mt-6 max-w-3xl text-base leading-7 text-fuchsia-100/80'
    >
      A direct gallery for commissioned artwork. Add images to <code
        class='rounded bg-black/20 px-2 py-1 text-fiction-gold'
        >public/fiction/commissions/
      </code> to show them here.
    </p>
    {images.length > 0 ? (
      <div class="mt-14 columns-1 gap-5 sm:columns-2 lg:columns-3">
        {images.map((image) => (
          <a
            href={image.src}
            class="mb-5 block break-inside-avoid overflow-hidden rounded-[2rem] border border-fiction-gold/30 bg-black/20 transition hover:border-fiction-gold/70"
            target="_blank"
          >
            <img
              src={image.src}
              alt={image.title}
              loading="lazy"
              class="w-full object-cover transition duration-500 hover:scale-[1.02]"
            />
            <div class="px-5 py-4 text-sm font-bold text-fuchsia-100/80">
              {image.title}
            </div>
          </a>
        ))}
      </div>
    ) : (
      <div
        data-page-i18n="commissions.empty"
        data-page-i18n-html
        class="mt-14 rounded-[2rem] border border-dashed border-fiction-gold/40 bg-black/20 p-8 text-base leading-7 text-fuchsia-100/80"
      >
        No commission images yet. Put image files in{' '}
        <code class="rounded bg-black/20 px-2 py-1 text-fiction-gold">
          public/fiction/commissions/
        </code>
        .
      </div>
    )}
  </section>
</FictionPage>
