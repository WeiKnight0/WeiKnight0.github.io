---
import FictionPage from '@/templates/FictionPage.astro';
---

<FictionPage
  title='Fiction | My Homepage'
  description='Original characters, worldbuilding, stories, and commissions.'
>
  <section class='mx-auto max-w-7xl px-5 py-24 lg:px-8'>
    <div
      class='grid min-h-[620px] items-start gap-16 lg:grid-cols-[1fr_420px]'
    >
      <div class="pt-10">
        <p
          data-page-i18n='fiction.kicker'
          class='mb-8 text-sm font-real-mono uppercase tracking-[0.3em] text-fiction-accent md:text-base border-l-2 border-fiction-accent pl-4'
        >
          Nijigen / story archive
        </p>
        <h1
          data-page-i18n='fiction.heading'
          class='font-fiction-serif text-5xl font-black leading-[1.1] tracking-wide text-fiction-text md:text-6xl lg:text-7xl drop-shadow-[0_2px_10px_rgba(0,0,0,0.8)]'
        >
          Where characters breathe, worlds branch, and stories wait.
        </h1>
        <p
          data-page-i18n='fiction.description'
          class='mt-10 max-w-2xl text-lg leading-loose text-white/70 font-fiction-serif bg-black/30 p-6 border border-white/5 shadow-inner'
        >
          Original characters, worldbuilding, stories, and commissioned artwork
          &mdash; arranged like an archive launcher.
        </p>
        
        <div class="mt-16 text-center opacity-40">
           <span class="inline-block w-1 h-1 rounded-full bg-fiction-accent mx-2 animate-pulse-slow"></span>
           <span class="inline-block w-1.5 h-1.5 rounded-full bg-fiction-accent mx-2 animate-pulse-slow" style="animation-delay: 1s"></span>
           <span class="inline-block w-1 h-1 rounded-full bg-fiction-accent mx-2 animate-pulse-slow" style="animation-delay: 2s"></span>
        </div>
      </div>
      
      {/* 魔法卷轴风格菜单 */}
      <div
        class='relative border border-fiction-accent/30 bg-fiction-surface/90 p-10 shadow-[0_0_40px_rgba(255,215,0,0.05)] backdrop-blur-sm'
      >
        <div class="absolute inset-0 border-[4px] border-double border-white/5 pointer-events-none m-2"></div>
        <p
          data-page-i18n='fiction.menu'
          class='text-center text-sm font-fiction-serif font-bold uppercase tracking-[0.3em] text-fiction-accent mb-8 pb-4 border-b border-fiction-accent/20'
        >
          Archive menu
        </p>
        <div class='mt-6 flex flex-col gap-6 font-fiction-serif'>
          <a
            class='group flex justify-between items-end border-b border-white/10 pb-2 hover:border-fiction-accent/50 transition-colors'
            data-page-href='oc'
            href='/fiction/oc/'
            >
            <span class="text-2xl text-fiction-text group-hover:text-fiction-accent transition-colors" data-page-i18n='fiction.ocs'>OCs</span>
            <span class="text-xs font-real-mono text-white/30 uppercase tracking-widest group-hover:text-fiction-accent/60">Entities</span>
          </a>
          <a
            class='group flex justify-between items-end border-b border-white/10 pb-2 hover:border-fiction-accent/50 transition-colors'
            data-page-href='world'
            href='/fiction/world/'
            >
            <span class="text-2xl text-fiction-text group-hover:text-fiction-accent transition-colors" data-page-i18n='fiction.world'>Worldbuilding</span>
            <span class="text-xs font-real-mono text-white/30 uppercase tracking-widest group-hover:text-fiction-accent/60">Lore</span>
          </a>
          <a
            class='group flex justify-between items-end border-b border-white/10 pb-2 hover:border-fiction-accent/50 transition-colors'
            data-page-href='novels'
            href='/fiction/novels/'
            >
            <span class="text-2xl text-fiction-text group-hover:text-fiction-accent transition-colors" data-page-i18n='fiction.stories'>Stories</span>
            <span class="text-xs font-real-mono text-white/30 uppercase tracking-widest group-hover:text-fiction-accent/60">Chronicles</span>
          </a>
          <a
            class='group flex justify-between items-end border-b border-white/10 pb-2 hover:border-fiction-accent/50 transition-colors'
            data-page-href='commissions'
            href='/fiction/commissions/'
            >
            <span class="text-2xl text-fiction-text group-hover:text-fiction-accent transition-colors" data-page-i18n='fiction.commissions'>Commissions</span>
            <span class="text-xs font-real-mono text-white/30 uppercase tracking-widest group-hover:text-fiction-accent/60">Gallery</span>
          </a>
        </div>
      </div>
    </div>
  </section>
</FictionPage>
