---
import { getCollection } from 'astro:content';

import FictionPage from '@/templates/FictionPage.astro';

const chapters = (await getCollection('novels')).sort(
  (a, b) => a.data.order - b.data.order
);
---

<FictionPage
  title='Stories | My Homepage'
  description='Stories and narrative chapters.'
>
  <section class='mx-auto max-w-[92rem] px-4 py-24 sm:px-6 lg:px-8'>
    <p
      data-page-i18n='novels.kicker'
      class='mb-6 text-base font-black uppercase tracking-[0.28em] text-fiction-gold md:text-lg'
    >
      Stories
    </p>
    <h1
      data-page-i18n='novels.heading'
      class='font-fiction text-4xl font-black leading-none tracking-[-0.05em] text-fiction-ink md:text-6xl'
    >
      Stories
    </h1>
    <div class='mt-14 grid gap-5'>
      {chapters.map((chapter) => (
        <a
          href={`/fiction/novels/${chapter.slug}/`}
          data-page-href-prefix="chapter"
          data-page-href-slug={`${chapter.slug}/`}
          class="rounded-[2rem] border border-fiction-gold/30 bg-black/20 p-7 transition hover:bg-fiction-gold/10"
        >
          <p
            data-page-i18n="novels.chapter"
            data-page-i18n-order={chapter.data.order}
            class="text-base font-bold text-fiction-gold"
          >
            Chapter {chapter.data.order}
          </p>
          <h2 class="mt-2 font-fiction text-3xl font-black text-fiction-ink">
            {chapter.data.title}
          </h2>
          <p class="mt-4 text-base leading-7 text-fuchsia-100/80">
            {chapter.data.description}
          </p>
        </a>
      ))}
    </div>
  </section>
</FictionPage>
