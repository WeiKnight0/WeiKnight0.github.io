---
import FictionPage from '@/templates/FictionPage.astro';
---

<FictionPage
  title='Original Characters | My Homepage'
  description='Original character overview.'
>
  <section class='mx-auto max-w-7xl px-5 py-24 lg:px-8'>
    <p class='mb-6 text-sm font-black uppercase tracking-[0.28em] md:text-base text-fiction-gold'>
      Original characters
    </p>
    <h1 class='font-fiction text-5xl font-black leading-none tracking-[-0.05em] text-fiction-ink md:text-7xl'>
      Original Characters
    </h1>
    <div class='mt-14 grid gap-5 md:grid-cols-2'>
      <a class='min-h-[420px] rounded-[2rem] border border-fiction-gold/30 bg-black/20 p-8 hover:bg-fiction-gold/10' href='/fiction/oc/oc-a/'>
        <p class='text-fiction-gold'>OC 01</p>
        <h2 class='mt-4 font-fiction text-5xl font-black text-fiction-ink'>Character A</h2>
        <p class='mt-5 leading-8 text-fuchsia-100/70'>
          Replace this with the character name, keywords, and a short hook.
        </p>
      </a>
      <a class='min-h-[420px] rounded-[2rem] border border-fiction-gold/30 bg-black/20 p-8 hover:bg-fiction-gold/10' href='/fiction/oc/oc-b/'>
        <p class='text-fiction-gold'>OC 02</p>
        <h2 class='mt-4 font-fiction text-5xl font-black text-fiction-ink'>Character B</h2>
        <p class='mt-5 leading-8 text-fuchsia-100/70'>
          Replace this with the character name, keywords, and a short hook.
        </p>
      </a>
    </div>
  </section>
</FictionPage>
