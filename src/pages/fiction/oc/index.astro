---
import FictionPage from '@/templates/FictionPage.astro';
---

<FictionPage
  title='Original Characters | My Homepage'
  description='Original character overview.'
>
  <section class='mx-auto max-w-7xl px-5 py-24 lg:px-8'>
    <p class='mb-4 border-l-2 border-fiction-accent pl-4 font-real-mono text-xs font-black uppercase tracking-[0.28em] md:text-sm text-fiction-accent'>
      Original characters
    </p>
    <h1 class='font-fiction-serif text-5xl font-black leading-none tracking-wide text-fiction-text md:text-7xl drop-shadow-[0_2px_10px_rgba(0,0,0,0.75)]'>
      Original Characters
    </h1>
    <div class='mt-14 grid gap-5 md:grid-cols-2'>
      <a class='group min-h-[420px] border border-fiction-accent/30 bg-fiction-surface/80 p-8 hover:border-fiction-accent/70 hover:bg-fiction-accent/10 transition-colors' href='/fiction/oc/oc-a/'>
        <p class='font-real-mono text-fiction-accent uppercase tracking-widest'>OC 01</p>
        <h2 class='mt-4 font-fiction-serif text-5xl font-black text-fiction-text group-hover:text-fiction-accent transition-colors'>Character A</h2>
        <p class='mt-5 font-fiction-serif leading-8 text-fiction-text/70'>
          Replace this with the character name, keywords, and a short hook.
        </p>
      </a>
      <a class='group min-h-[420px] border border-fiction-accent/30 bg-fiction-surface/80 p-8 hover:border-fiction-accent/70 hover:bg-fiction-accent/10 transition-colors' href='/fiction/oc/oc-b/'>
        <p class='font-real-mono text-fiction-accent uppercase tracking-widest'>OC 02</p>
        <h2 class='mt-4 font-fiction-serif text-5xl font-black text-fiction-text group-hover:text-fiction-accent transition-colors'>Character B</h2>
        <p class='mt-5 font-fiction-serif leading-8 text-fiction-text/70'>
          Replace this with the character name, keywords, and a short hook.
        </p>
      </a>
    </div>
  </section>
</FictionPage>
