---
import FictionPage from '@/templates/FictionPage.astro';

const sections = ['Profile', 'Personality / History', 'Relationships', 'Visual Materials'];
---

<FictionPage title='Character B | My Homepage' description='OC character file B.'>
  <section class='mx-auto max-w-7xl px-5 py-24 lg:px-8'>
    <p class='mb-6 text-sm font-black uppercase tracking-[0.28em] md:text-base text-fiction-gold'>
      Character file 02
    </p>
    <h1 class='font-fiction text-5xl font-black leading-none tracking-[-0.05em] text-fiction-ink md:text-7xl'>
      Character B
    </h1>
    <div class='mt-14 grid gap-5 md:grid-cols-2'>
      {sections.map((item) => (
        <article class="rounded-[2rem] border border-fiction-gold/30 bg-black/20 p-7">
          <h2 class="font-fiction text-3xl font-black text-fiction-ink">{item}</h2>
          <p class="mt-4 leading-8 text-fuchsia-100/70">
            Waiting for character details.
          </p>
        </article>
      ))}
    </div>
  </section>
</FictionPage>
