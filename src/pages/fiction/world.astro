---
import FictionPage from '@/templates/FictionPage.astro';
---

<FictionPage title='Worldbuilding | My Homepage' description='Worldbuilding archive.'>
  <section class='mx-auto max-w-[92rem] px-4 py-24 sm:px-6 lg:px-8'>
    <p class='mb-6 text-base font-black uppercase tracking-[0.28em] text-fiction-gold md:text-lg'>
      Worldbuilding
    </p>
    <h1 class='font-fiction text-4xl font-black leading-none tracking-[-0.05em] text-fiction-ink md:text-6xl'>
      Worldbuilding
    </h1>
    <div class='mt-14 rounded-[2rem] border border-fiction-gold/30 bg-black/20 p-8'>
      <h2 class='font-fiction text-3xl font-black text-fiction-ink'>Coming Soon</h2>
      <p class='mt-4 max-w-3xl text-base leading-7 text-fuchsia-100/80'>
        English worldbuilding archive is not available yet. Please visit the Chinese version for the current content.
      </p>
      <a href='/zh-cn/fiction/world/' class='mt-6 inline-flex rounded-full border border-fiction-gold/50 px-5 py-2 text-sm font-bold text-fiction-gold transition hover:bg-fiction-gold/10 hover:text-fiction-ink'>
        中文世界观
      </a>
    </div>
  </section>
</FictionPage>
