---
import { getCollection } from 'astro:content';

import FictionPage from '@/templates/FictionPage.astro';

export async function getStaticPaths() {
  const items = await getCollection('world');

  return items.map((item) => ({ params: { slug: item.slug }, props: { item } }));
}

const { item } = Astro.props;
const { Content } = await item.render();
---

<FictionPage title={`${item.data.title} | Worldbuilding | My Homepage`} description={item.data.description}>
  <article class='mx-auto max-w-6xl px-4 py-24 sm:px-6 lg:px-8'>
    <a href='/fiction/world/' class='text-base font-bold text-fiction-gold transition hover:text-fiction-ink'>← Back to worldbuilding</a>
    <p class='mt-10 text-base font-black uppercase tracking-[0.28em] text-fiction-gold md:text-lg'>Worldbuilding</p>
    <h1 class='mt-6 font-fiction text-3xl font-black leading-tight tracking-[-0.035em] text-fiction-ink md:text-5xl'>{item.data.title}</h1>
    <p class='mt-6 text-lg leading-8 text-fuchsia-100/80'>{item.data.description}</p>
    <div class='world-prose prose prose-base prose-invert mt-14 max-w-none prose-headings:font-fiction prose-headings:text-fiction-ink prose-a:text-fiction-gold prose-strong:text-fiction-ink prose-blockquote:not-italic md:prose-lg'>
      <Content />
    </div>
  </article>
</FictionPage>

<style>
  .world-prose :global(blockquote p:first-of-type::before),
  .world-prose :global(blockquote p:last-of-type::after) {
    content: none !important;
    display: none !important;
  }
</style>
