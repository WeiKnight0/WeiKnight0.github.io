---
import Base from '@/templates/Base.astro';
import { AppConfig } from '@/utils/AppConfig';
import { Profile } from '@/utils/Profile';

const { title, description } = AppConfig;
---

<Base head={{ title, description }} theme='home'>
  <main class="bg-black text-white font-sans selection:bg-white/20">
    {/* 顶部巨幕区 - 保留并强化日文注音与双轨世界观 */}
    <section class='relative min-h-[90vh] flex flex-col justify-center overflow-hidden bg-black border-b border-white/10'>
      {/* 复杂的背景光效 */}
      <div class='pointer-events-none absolute inset-0'>
        <div class='absolute inset-0 bg-[linear-gradient(rgba(255,255,255,0.03)_1px,transparent_1px),linear-gradient(90deg,rgba(255,255,255,0.03)_1px,transparent_1px)] bg-[size:64px_64px]'></div>
        <div class='absolute left-[-10%] top-[-10%] w-[50%] h-[50%] bg-real-accent/10 rounded-full blur-[150px] mix-blend-screen'></div>
        <div class='absolute right-[-10%] bottom-[-10%] w-[50%] h-[50%] bg-fiction-accent/10 rounded-full blur-[150px] mix-blend-screen'></div>
      </div>

      <div class='relative z-10 mx-auto w-full max-w-7xl px-6 py-20 text-center'>
        {/* 中心化身 - 绝对无滤镜 */}
        <div class="mb-12 flex justify-center relative">
           <div class="absolute inset-0 bg-white/5 blur-2xl rounded-full scale-150"></div>
           <img
              src={Profile.avatar}
              alt={`${Profile.name} avatar`}
              class='relative h-32 w-32 md:h-40 md:w-40 rounded-full border-4 border-white/10 shadow-[0_0_40px_rgba(255,255,255,0.1)]'
            />
        </div>

        {/* 主标题 - 日文 Ruby */}
        <h1 class='font-jp-display max-w-5xl mx-auto text-4xl font-black leading-[1.2] tracking-widest text-white md:text-6xl'>
          <span class='block text-lg font-bold tracking-[0.3em] text-white/50 md:text-xl mb-6'>
            ― <ruby>二<rt class="text-[0.5em] tracking-widest text-white/40">ふた</rt></ruby>つの<ruby>世界<rt class="text-[0.5em] tracking-widest text-white/40">せかい</rt></ruby>を<ruby>渡<rt class="text-[0.5em] tracking-widest text-white/40">わた</rt></ruby>る<ruby>者<rt class="text-[0.5em] tracking-widest text-white/40">もの</rt></ruby> ―
          </span>
          <span class='block bg-gradient-to-r from-real-accent via-white to-fiction-accent bg-clip-text text-transparent'>
            <ruby>三次元<rt class="text-[0.4em] text-real-accent/80 tracking-widest">さんじげん</rt></ruby> と <ruby>二次元<rt class="text-[0.4em] text-fiction-accent/80 tracking-widest">にじげん</rt></ruby>、<ruby>二<rt class="text-[0.4em] text-white/80 tracking-widest">ふた</rt></ruby>つの<ruby>記録<rt class="text-[0.4em] text-white/80 tracking-widest">アーカイブ</rt></ruby>
          </span>
        </h1>

        {/* 个人简介区 */}
        <div class="mt-16 max-w-2xl mx-auto">
          <h2 class="text-3xl font-black mb-4">{Profile.name}</h2>
          <p class="text-white/60 text-lg leading-relaxed mb-8">{Profile.tagline}</p>
          
          <div class="flex flex-wrap justify-center gap-3 mb-8">
            {Profile.techStack.map((tech) => (
              <span class='px-4 py-1.5 border border-white/20 bg-white/5 text-xs font-real-mono uppercase tracking-widest text-white/80'>
                {tech}
              </span>
            ))}
          </div>

          <div class="flex justify-center gap-6 font-real-mono text-sm uppercase tracking-widest">
            <a href={Profile.github} class="text-real-accent hover:text-white transition-colors">GitHub_</a>
            <a href={Profile.bilibili} class="text-fiction-accent hover:text-white transition-colors">Bilibili*</a>
          </div>
        </div>
      </div>
    </section>

    {/* 高密度信息面板区 (Bento Box 风格) */}
    <section class='mx-auto max-w-7xl px-6 py-24'>
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
        
        {/* --- REAL 面板 --- */}
        <div class="border border-white/10 bg-[#050A0F] relative overflow-hidden group">
          <div class="absolute inset-0 bg-[linear-gradient(rgba(0,229,255,0.05)_1px,transparent_1px),linear-gradient(90deg,rgba(0,229,255,0.05)_1px,transparent_1px)] bg-[size:16px_16px] opacity-20"></div>
          
          <div class="relative z-10 p-8 md:p-12">
            <div class="flex items-center justify-between mb-8 border-b border-real-accent/20 pb-4">
               <h3 class="font-real-mono text-2xl font-black text-white"><span class="text-real-accent mr-2">A/</span>REAL_SIDE</h3>
               <span class="text-xs font-real-mono text-real-accent uppercase tracking-widest px-2 py-1 bg-real-accent/10 border border-real-accent/30">System.out</span>
            </div>
            
            <p class="text-white/60 text-sm mb-10 font-real-mono leading-relaxed">
              Engineering records, project architectures, and technical logs. The mechanical reality where ideas are built into systems.
            </p>

            {/* 精选项目预览 */}
            <div class="mb-10">
               <h4 class="text-xs font-real-mono text-white/40 uppercase tracking-[0.2em] mb-4">Featured_Deployments</h4>
               <div class="space-y-4">
                  {Profile.repos.slice(0, 3).map(repo => (
                    <a href={repo.href} class="block p-4 border border-white/5 bg-white/[0.02] hover:border-real-accent/50 hover:bg-real-accent/5 transition-all">
                       <div class="font-real-mono font-bold text-real-accent mb-1">{repo.name}</div>
                       <div class="text-xs text-white/50">{repo.description}</div>
                    </a>
                  ))}
               </div>
            </div>

            <div class="grid grid-cols-2 gap-4 font-real-mono text-sm">
               <a href="/real/resume/" class="p-4 border border-white/10 text-center hover:bg-real-accent hover:text-black transition-colors font-bold uppercase tracking-widest">Resume</a>
               <a href="/real/notes/" class="p-4 border border-white/10 text-center hover:bg-real-accent hover:text-black transition-colors font-bold uppercase tracking-widest">Notes</a>
               <a href="/real/projects/" class="p-4 border border-white/10 text-center hover:bg-real-accent hover:text-black transition-colors font-bold uppercase tracking-widest">Projects</a>
               <a href="/real/blog/" class="p-4 border border-white/10 text-center hover:bg-real-accent hover:text-black transition-colors font-bold uppercase tracking-widest">Blogs</a>
            </div>

            <a href="/real/" class="mt-8 block w-full py-4 bg-real-accent/10 text-real-accent border border-real-accent/30 text-center font-real-mono uppercase tracking-[0.2em] text-sm hover:bg-real-accent hover:text-black transition-colors">
              Initialize Real Environment &rarr;
            </a>
          </div>
        </div>

        {/* --- FICTION 面板 --- */}
        <div class="border border-white/10 bg-[#110A14] relative overflow-hidden group">
          <div class="absolute inset-0 opacity-[0.05] mix-blend-overlay" style="background-image: url('data:image/svg+xml,%3Csvg viewBox=%220 0 200 200%22 xmlns=%22http://www.w3.org/2000/svg%22%3E%3Cfilter id=%22noiseFilter%22%3E%3CfeTurbulence type=%22fractalNoise%22 baseFrequency=%220.8%22 numOctaves=%223%22 stitchTiles=%22stitch%22/%3E%3C/filter%3E%3Crect width=%22100%25%22 height=%22100%25%22 filter=%22url(%23noiseFilter)%22/%3E%3C/svg%3E');"></div>
          
          <div class="relative z-10 p-8 md:p-12 h-full flex flex-col">
            <div class="flex items-center justify-between mb-8 border-b border-fiction-accent/20 pb-4">
               <h3 class="font-fiction-serif text-2xl font-black text-white italic"><span class="text-fiction-accent mr-2 not-italic">B/</span>FICTION_SIDE</h3>
               <span class="text-xs font-sans text-fiction-accent uppercase tracking-widest px-2 py-1 bg-fiction-accent/10 border border-fiction-accent/30">Archive.log</span>
            </div>
            
            <p class="text-white/60 text-sm mb-10 font-fiction-serif leading-relaxed">
              Narratives, character entities, and worldbuilding fragments. The creative archive where imagination takes form.
            </p>

            {/* 档案分区预览 */}
            <div class="mb-10 flex-grow">
               <h4 class="text-xs font-sans text-white/40 uppercase tracking-[0.2em] mb-4">Archive_Directories</h4>
               <div class="grid grid-cols-1 gap-4 font-fiction-serif">
                  <a href="/fiction/world/" class="p-4 border border-white/5 bg-white/[0.02] hover:border-fiction-accent/50 hover:bg-fiction-accent/5 transition-all flex justify-between items-center">
                    <span class="text-lg text-white">世界观設定</span>
                    <span class="text-xs text-fiction-accent font-sans uppercase tracking-widest">Worldbuilding</span>
                  </a>
                  <a href="/fiction/oc/" class="p-4 border border-white/5 bg-white/[0.02] hover:border-fiction-accent/50 hover:bg-fiction-accent/5 transition-all flex justify-between items-center">
                    <span class="text-lg text-white">人物記録</span>
                    <span class="text-xs text-fiction-accent font-sans uppercase tracking-widest">Original Characters</span>
                  </a>
                  <a href="/fiction/novels/" class="p-4 border border-white/5 bg-white/[0.02] hover:border-fiction-accent/50 hover:bg-fiction-accent/5 transition-all flex justify-between items-center">
                    <span class="text-lg text-white">物語断片</span>
                    <span class="text-xs text-fiction-accent font-sans uppercase tracking-widest">Stories</span>
                  </a>
                  <a href="/fiction/commissions/" class="p-4 border border-white/5 bg-white/[0.02] hover:border-fiction-accent/50 hover:bg-fiction-accent/5 transition-all flex justify-between items-center">
                    <span class="text-lg text-white">画廊</span>
                    <span class="text-xs text-fiction-accent font-sans uppercase tracking-widest">Gallery</span>
                  </a>
               </div>
            </div>

            <a href="/fiction/" class="mt-auto block w-full py-4 bg-fiction-accent/10 text-fiction-accent border border-fiction-accent/30 text-center font-sans uppercase tracking-[0.2em] text-sm hover:bg-fiction-accent hover:text-black transition-colors font-bold">
              Open Story Nexus &rarr;
            </a>
          </div>
        </div>

      </div>
    </section>
  </main>
</Base>
