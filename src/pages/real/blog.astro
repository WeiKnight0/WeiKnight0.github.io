---
import { getCollection } from 'astro:content';

import RealPage from '@/templates/RealPage.astro';

const posts = (await getCollection('blog'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const dateFormatter = new Intl.DateTimeFormat('en', { dateStyle: 'medium' });
const getPostDescription = (post: (typeof posts)[number]) =>
  post.data.description ?? post.data.title;
---

<RealPage
  title='Blogs | My Homepage'
  description='Blog posts and long-term records.'
>
  <section class='mx-auto max-w-[92rem] px-4 py-24 sm:px-6 lg:px-8'>
    <div class='border-b border-real-accent/30 pb-6'>
      <p class='mb-4 text-xs font-real-mono font-black uppercase tracking-[0.28em] text-real-accent md:text-sm'>
        <span data-page-i18n='blog.kicker'>Blogs</span>
      </p>
      <div class='flex flex-wrap items-end justify-between gap-5'>
        <h1
          data-page-i18n='blog.heading'
          class='font-real-mono text-4xl font-black leading-none tracking-tight text-real-text md:text-6xl drop-shadow-[0_0_14px_rgba(0,245,255,0.18)]'
        >
          Blogs
        </h1>
        <a
          href='/real/blog/tags/'
          data-page-href='tags'
          data-page-i18n='blog.tags'
          class='border border-real-accent/40 bg-real-accent/10 px-4 py-2 font-real-mono text-sm font-bold uppercase tracking-widest text-real-accent transition hover:bg-real-accent hover:text-black'
          >Browse tags
        </a>
      </div>
    </div>
    <div class='mt-14 grid gap-5 md:grid-cols-3'>
      {posts.map((post) => (
        <a
          href={`/real/blog/${post.slug}/`}
          data-page-href-prefix="post"
          data-page-href-slug={`${post.slug}/`}
          class="group relative overflow-hidden border border-white/10 bg-real-surface p-7 transition hover:border-real-accent/60 hover:bg-real-accent/5"
        >
          <div class='absolute left-0 top-0 h-full w-1 origin-top scale-y-0 bg-real-accent transition-transform group-hover:scale-y-100'></div>
          <p class="font-real-mono text-sm font-bold text-real-accent">
            {dateFormatter.format(post.data.date)}
          </p>
          <h2 class="mt-3 font-real-mono text-2xl font-black leading-tight text-real-text transition group-hover:text-real-accent">
            {post.data.title}
          </h2>
          <p class="mt-4 text-base leading-7 text-real-text/75 font-real-sans">
            {getPostDescription(post)}
          </p>
          {post.data.tags.length > 0 && (
            <div class="mt-6 flex flex-wrap gap-2">
              {post.data.tags.map((tag) => (
                <span class="border border-real-accent/20 bg-black/30 px-3 py-1 text-xs font-real-mono font-bold uppercase tracking-wider text-real-accent/80">
                  {tag}
                </span>
              ))}
            </div>
          )}
        </a>
      ))}
    </div>
  </section>
</RealPage>
