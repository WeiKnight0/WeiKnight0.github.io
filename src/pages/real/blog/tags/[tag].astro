---
import { getCollection } from 'astro:content';

import RealPage from '@/templates/RealPage.astro';

export async function getStaticPaths() {
  const posts = (await getCollection('blog')).filter((post) => !post.data.draft);
  const tags = [...new Set(posts.flatMap((post) => post.data.tags))];

  return tags.map((tag) => ({
    params: { tag: encodeURIComponent(tag) },
    props: { tag },
  }));
}

const { tag } = Astro.props;
const posts = (await getCollection('blog'))
  .filter((post) => !post.data.draft && post.data.tags.includes(tag))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const dateFormatter = new Intl.DateTimeFormat('en', { dateStyle: 'medium' });
const getPostDescription = (post: (typeof posts)[number]) =>
  post.data.description ?? post.data.title;
---

<RealPage title={`${tag} | Blogs | My Homepage`} description={`Blog posts tagged ${tag}.`}>
  <section class='mx-auto max-w-[92rem] px-4 py-24 sm:px-6 lg:px-8'>
    <a href='/real/blog/tags/' class='text-base font-bold text-cyan-300 transition hover:text-cyan-200'>
      ← All tags
    </a>
    <p class='mt-10 text-base font-black uppercase tracking-[0.28em] text-cyan-300 md:text-lg'>
      Blogs / Tag
    </p>
    <h1 class='mt-6 text-4xl font-black leading-none tracking-[-0.05em] text-white md:text-6xl'>
      {tag}
    </h1>
    <div class='mt-14 grid gap-5 md:grid-cols-3'>
      {posts.map((post) => (
        <a
          href={`/real/blog/${post.slug}/`}
          class='rounded-3xl border border-white/10 bg-white/[0.04] p-7 transition hover:border-cyan-300/40 hover:bg-white/[0.07]'
        >
          <p class='text-base font-bold text-cyan-300'>{dateFormatter.format(post.data.date)}</p>
          <h2 class='mt-3 text-2xl font-black leading-tight text-white'>{post.data.title}</h2>
          <p class='mt-4 text-base leading-7 text-slate-300'>{getPostDescription(post)}</p>
        </a>
      ))}
    </div>
  </section>
</RealPage>
