---
import { getCollection } from 'astro:content';

import RealPage from '@/templates/RealPage.astro';

const posts = (await getCollection('blog')).filter((post) => !post.data.draft);
const tagCounts = posts.reduce<Record<string, number>>((counts, post) => {
  post.data.tags.forEach((tag) => {
    counts[tag] = (counts[tag] ?? 0) + 1;
  });
  return counts;
}, {});
const tags = Object.entries(tagCounts).sort(([a], [b]) => a.localeCompare(b));
---

<RealPage title='Tags | Blogs | My Homepage' description='Browse blog posts by tag.'>
  <section class='mx-auto max-w-6xl px-4 py-24 sm:px-6 lg:px-8'>
    <a href='/real/blog/' class='text-base font-bold text-cyan-300 transition hover:text-cyan-200'>
      ← Back to blogs
    </a>
    <p class='mt-10 text-base font-black uppercase tracking-[0.28em] text-cyan-300 md:text-lg'>
      Blogs
    </p>
    <h1 class='mt-6 text-4xl font-black leading-none tracking-[-0.05em] text-white md:text-6xl'>
      Tags
    </h1>
    <div class='mt-12 flex flex-wrap gap-3'>
      {tags.map(([tag, count]) => (
        <a
          href={`/real/blog/tags/${encodeURIComponent(tag)}/`}
          class='rounded-full border border-cyan-300/20 bg-white/[0.04] px-4 py-2 text-base font-bold text-cyan-100 transition hover:border-cyan-300/50 hover:bg-cyan-300/10'
        >
          {tag} <span class='text-cyan-300/70'>({count})</span>
        </a>
      ))}
    </div>
  </section>
</RealPage>
