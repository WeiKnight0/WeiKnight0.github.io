---
import { getCollection } from 'astro:content';

import NotePage from '@/templates/NotePage.astro';
import {
  formatSubjectName,
  getNotePath,
  getSubjectNotes,
  getTopLevelNotes,
} from '@/utils/notes';

const notes = (await getCollection('notes')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

const subjects = getSubjectNotes(notes);
const topLevelNotes = getTopLevelNotes(notes).filter((note) => note.id !== 'index.md');
const subjectNames = Object.keys(subjects).sort((a, b) =>
  formatSubjectName(a).localeCompare(formatSubjectName(b))
);
---

<NotePage
  title="WeiKnight's Study Notes Index"
  description='Study and practice notes.'
  date={new Date('2025-07-29T15:29:52')}
  showBackLink={false}
>
  <h1>Subjects Index</h1>
  <p>Currently available subjects:</p>
  <ul>
    {subjectNames.map((subject) => (
      <li>
        <a href={`/real/notes/${subject}/`}>{formatSubjectName(subject)}</a>
      </li>
    ))}
  </ul>

  <h2>Standalone Notes</h2>
  <ul>
    {topLevelNotes.map((note) => (
      <li>
        <a href={`/real/notes/${getNotePath(note.id)}/`}>{note.data.title}</a>
      </li>
    ))}
  </ul>

  <p>Also, you can check out my GitHub repositories for more study materials:</p>
  <ul>
    <li>
      <a href='https://github.com/WeiKnight0/MachineLearningStudy'>Machine Learning</a>
    </li>
  </ul>
</NotePage>
