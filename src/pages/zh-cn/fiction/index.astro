---
import FictionPage from '@/templates/FictionPage.astro';
---

<FictionPage
  title='幻想侧 | 个人主页'
  description='原创角色、世界观、故事与委托作品档案。'
  locale='zh-cn'
>
  <section class='mx-auto max-w-7xl px-5 py-24 lg:px-8'>
    <div
      class='grid min-h-[620px] items-center gap-12 lg:grid-cols-[1fr_420px]'
    >
      <div>
        <p
          class='mb-6 text-sm font-black uppercase tracking-[0.28em] md:text-base text-fiction-gold'
        >
          二次元 / 物语档案
        </p>
        <h1
          class='font-fiction text-5xl font-black leading-[0.92] tracking-[-0.05em] text-fiction-ink md:text-7xl'
        >
          角色在此呼吸，世界在此分岔，故事在此等待。
        </h1>
        <p class='mt-8 max-w-3xl text-lg leading-8 text-fuchsia-100/70'>
          原创角色、世界观、故事章节与委托图像，以档案的方式陈列。
        </p>
      </div>
      <div
        class='rounded-[2rem] border border-fiction-gold/30 bg-white/5 p-6 shadow-2xl shadow-black/30'
      >
        <p
          class='text-sm font-black uppercase tracking-[0.22em] md:text-base text-fiction-gold'
        >
          档案菜单
        </p>
        <div class='mt-6 grid gap-3'>
          <a
            class='rounded-2xl border border-fiction-gold/20 bg-black/20 px-4 py-3 font-bold text-fiction-ink hover:bg-fiction-gold/10'
            href='/zh-cn/fiction/oc/'
            >OCs
          </a>
          <a
            class='rounded-2xl border border-fiction-gold/20 bg-black/20 px-4 py-3 font-bold text-fiction-ink hover:bg-fiction-gold/10'
            href='/zh-cn/fiction/world/'
            >世界观
          </a>
          <a
            class='rounded-2xl border border-fiction-gold/20 bg-black/20 px-4 py-3 font-bold text-fiction-ink hover:bg-fiction-gold/10'
            href='/zh-cn/fiction/novels/'
            >故事
          </a>
          <a
            class='rounded-2xl border border-fiction-gold/20 bg-black/20 px-4 py-3 font-bold text-fiction-ink hover:bg-fiction-gold/10'
            href='/zh-cn/fiction/commissions/'
            >委托作品
          </a>
        </div>
      </div>
    </div>
  </section>
</FictionPage>
