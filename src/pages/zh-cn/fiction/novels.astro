---
import { getCollection } from 'astro:content';

import FictionPage from '@/templates/FictionPage.astro';

const chapters = (await getCollection('novels')).sort(
  (a, b) => a.data.order - b.data.order
);
---

<FictionPage
  title='故事 | 个人主页'
  description='故事与剧情章节。'
  locale='zh-cn'
>
  <section class='mx-auto max-w-7xl px-5 py-24 lg:px-8'>
    <p
      class='mb-6 text-xs font-black uppercase tracking-[0.35em] text-fiction-gold'
    >
      Stories
    </p>
    <h1
      class='font-fiction text-6xl font-black leading-none tracking-[-0.05em] text-fiction-ink md:text-8xl'
    >
      故事
    </h1>
    <div class='mt-14 grid gap-5'>
      {chapters.map((chapter) => (
        <article class="rounded-[2rem] border border-fiction-gold/30 bg-black/20 p-7">
          <p class="text-fiction-gold">第 {chapter.data.order} 章</p>
          <h2 class="mt-2 font-fiction text-3xl font-black text-fiction-ink">
            {chapter.data.title}
          </h2>
          <p class="mt-4 leading-8 text-fuchsia-100/70">
            {chapter.data.description}
          </p>
        </article>
      ))}
    </div>
  </section>
</FictionPage>
