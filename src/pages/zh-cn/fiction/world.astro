---
import { getCollection } from 'astro:content';

import FictionPage from '@/templates/FictionPage.astro';

const items = (await getCollection('world')).sort(
  (a, b) => a.data.order - b.data.order
).filter((item) => item.slug.startsWith('zh-cn/'));

const getWorldSlug = (slug: string) => slug.split('/').at(-1);
const theoryItems = items.filter((item) => item.slug.startsWith('zh-cn/theory/'));
const settingItems = items.filter((item) => item.slug.startsWith('zh-cn/setting/'));
---

<FictionPage
  title='世界观 | 个人主页'
  description='世界观设定档案。'
  locale='zh-cn'
>
  <section class='mx-auto max-w-[92rem] px-4 py-24 sm:px-6 lg:px-8'>
    <p
      class='mb-6 text-base font-black uppercase tracking-[0.28em] text-fiction-gold md:text-lg'
    >
      Worldbuilding
    </p>
    <h1
      class='font-fiction text-4xl font-black leading-none tracking-[-0.05em] text-fiction-ink md:text-6xl'
    >
      世界观
    </h1>
    <section class='mt-14'>
      <h2 class='font-fiction text-3xl font-black text-fiction-ink md:text-4xl'>
        理论介绍
      </h2>
      <div class='mt-7 grid gap-5 md:grid-cols-3'>
        {theoryItems.map((item) => (
          <a
            href={`/zh-cn/fiction/world/${getWorldSlug(item.slug)}/`}
            class="rounded-[2rem] border border-fiction-gold/30 bg-black/20 p-7 transition hover:bg-fiction-gold/10"
          >
            <h3 class="font-fiction text-3xl font-black text-fiction-ink">
              {item.data.title}
            </h3>
            <p class="mt-4 text-base leading-7 text-fuchsia-100/80">
              {item.data.description}
            </p>
          </a>
        ))}
      </div>
    </section>

    <section class='mt-16'>
      <h2 class='font-fiction text-3xl font-black text-fiction-ink md:text-4xl'>
        世界观介绍
      </h2>
      <div class='mt-7 grid gap-5 md:grid-cols-3'>
        {settingItems.map((item) => (
          <a
            href={`/zh-cn/fiction/world/${getWorldSlug(item.slug)}/`}
            class="rounded-[2rem] border border-fiction-gold/30 bg-black/20 p-7 transition hover:bg-fiction-gold/10"
          >
            <h3 class="font-fiction text-3xl font-black text-fiction-ink">
              {item.data.title}
            </h3>
            <p class="mt-4 text-base leading-7 text-fuchsia-100/80">
              {item.data.description}
            </p>
          </a>
        ))}
      </div>
    </section>
  </section>
</FictionPage>
