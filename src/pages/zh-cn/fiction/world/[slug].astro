---
import { getCollection } from 'astro:content';

import FictionPage from '@/templates/FictionPage.astro';

export async function getStaticPaths() {
  const items = await getCollection('world');

  return items.map((item) => ({
    params: { slug: item.slug },
    props: { item },
  }));
}

const { item } = Astro.props;
const { Content } = await item.render();
---

<FictionPage
  title={`${item.data.title} | 世界观 | 个人主页`}
  description={item.data.description}
  locale='zh-cn'
>
  <article class='mx-auto max-w-4xl px-5 py-24 lg:px-8'>
    <a
      href='/zh-cn/fiction/world/'
      class='text-sm font-bold text-fiction-gold transition hover:text-fiction-ink'
      >← 返回世界观</a
    >
    <p
      class='mt-10 text-sm font-black uppercase tracking-[0.28em] md:text-base text-fiction-gold'
    >
      Worldbuilding
    </p>
    <h1
      class='mt-6 font-fiction text-4xl font-black leading-none tracking-[-0.04em] text-fiction-ink md:text-6xl'
    >
      {item.data.title}
    </h1>
    <p class='mt-6 text-lg leading-8 text-fuchsia-100/70'>
      {item.data.description}
    </p>
    <div class='prose prose-invert mt-14 max-w-none prose-headings:font-fiction prose-headings:text-fiction-ink prose-a:text-fiction-gold prose-strong:text-fiction-ink'>
      <Content />
    </div>
  </article>
</FictionPage>
