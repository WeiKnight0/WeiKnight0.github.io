---
import { getCollection } from 'astro:content';

import FictionPage from '@/templates/FictionPage.astro';

export async function getStaticPaths() {
  const items = (await getCollection('world')).filter(
    (item) => item.slug.startsWith('zh-cn/')
  );

  return items.map((item) => ({
    params: { slug: item.slug.split('/').at(-1) },
    props: { item },
  }));
}

const { item } = Astro.props;
const { Content } = await item.render();
---

<FictionPage
  title={`${item.data.title} | 世界观 | 个人主页`}
  description={item.data.description}
  locale='zh-cn'
>
  <article class='mx-auto max-w-6xl px-4 py-24 sm:px-6 lg:px-8'>
    <a
      href='/zh-cn/fiction/world/'
      class='text-base font-bold text-fiction-gold transition hover:text-fiction-ink'
      >← 返回世界观</a
    >
    <p
      class='mt-10 text-base font-black uppercase tracking-[0.28em] text-fiction-gold md:text-lg'
    >
      Worldbuilding
    </p>
    <h1
      class='mt-6 font-fiction text-3xl font-black leading-tight tracking-[-0.035em] text-fiction-ink md:text-5xl'
    >
      {item.data.title}
    </h1>
    <p class='mt-6 text-lg leading-8 text-fuchsia-100/80'>
      {item.data.description}
    </p>
    <div class='world-prose prose prose-base prose-invert mt-14 max-w-none prose-headings:font-fiction prose-headings:text-fiction-ink prose-a:text-fiction-gold prose-strong:text-fiction-ink prose-blockquote:not-italic md:prose-lg'>
      <Content />
    </div>
  </article>
</FictionPage>

<style>
  .world-prose :global(blockquote p:first-of-type::before),
  .world-prose :global(blockquote p:last-of-type::after) {
    content: none !important;
    display: none !important;
  }

  .world-prose :global(.env) {
    border-radius: 0.75rem;
    padding: 1rem 1.25rem;
    margin: 1.25rem 0;
    border-left-width: 4px;
    border-left-style: solid;
    background: rgba(0, 0, 0, 0.15);
  }

  .world-prose :global(.env .env-title) {
    font-weight: 700;
    margin-bottom: 0.5rem;
    font-size: 1.05em;
  }

  .world-prose :global(.env.definition) {
    border-left-color: #60a5fa;
    background: rgba(59, 130, 246, 0.06);
  }
  .world-prose :global(.env.definition .env-title) { color: #93c5fd; }

  .world-prose :global(.env.theorem) {
    border-left-color: #fbbf24;
    background: rgba(251, 191, 36, 0.06);
  }
  .world-prose :global(.env.theorem .env-title) { color: #fde68a; }

  .world-prose :global(.env.proof) {
    border-left-color: #9ca3af;
    background: rgba(156, 163, 175, 0.06);
    font-style: italic;
  }
  .world-prose :global(.env.proof .env-title) { color: #d1d5db; }

  .world-prose :global(.env.example) {
    border-left-color: #34d399;
    background: rgba(52, 211, 153, 0.06);
  }
  .world-prose :global(.env.example .env-title) { color: #6ee7b7; }

  .world-prose :global(.env.remark) {
    border-left-color: #c084fc;
    background: rgba(192, 132, 252, 0.06);
  }
  .world-prose :global(.env.remark .env-title) { color: #d8b4fe; }

  .world-prose :global(.env.axiom) {
    border-left-color: #f87171;
    background: rgba(248, 113, 113, 0.06);
  }
  .world-prose :global(.env.axiom .env-title) { color: #fca5a5; }

  .world-prose :global(.env.corollary) {
    border-left-color: #fb923c;
    background: rgba(251, 146, 60, 0.06);
  }
  .world-prose :global(.env.corollary .env-title) { color: #fed7aa; }

  .world-prose :global(.env.lemma) {
    border-left-color: #a78bfa;
    background: rgba(167, 139, 250, 0.06);
  }
  .world-prose :global(.env.lemma .env-title) { color: #c4b5fd; }
</style>
