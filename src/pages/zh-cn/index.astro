---
import Base from '@/templates/Base.astro';
import { Profile } from '@/utils/Profile';

const title = 'WEIKNIGHT | 个人主页';
const description = 'WEIKNIGHT 的个人主页，记录现实技术与幻想档案。';
---

<Base head={{ title, description }} theme='home' locale='zh-cn'>
  <main>
    <section class='relative min-h-screen overflow-hidden bg-slate-950'>
      <div class='pointer-events-none absolute inset-0'>
        <div
          class='absolute left-0 top-0 h-full w-1/2 bg-gradient-to-br from-cyan-500/20 via-blue-600/10 to-transparent'
        >
        </div>
        <div
          class='absolute right-0 top-0 h-full w-1/2 bg-gradient-to-bl from-fuchsia-500/20 via-purple-600/10 to-transparent'
        >
        </div>
        <div
          class='absolute left-1/2 top-1/3 h-[420px] w-[420px] -translate-x-1/2 -translate-y-1/2 rounded-full bg-gradient-to-br from-cyan-400/10 via-fuchsia-400/10 to-transparent blur-3xl'
        >
        </div>
      </div>

      <div
        class='relative z-10 mx-auto flex min-h-screen max-w-7xl flex-col items-center justify-center px-5 py-24 text-center lg:px-8'
      >
        <h1
          class='font-jp max-w-5xl text-4xl font-black leading-[0.94] tracking-[-0.03em] text-white md:text-6xl lg:text-7xl'
        >
          <span class='block text-lg font-bold tracking-[0.2em] text-white/40 md:text-xl'
            >― 二つの世界を統べる者 ―</span
          >
          <span class='hero-title-ruby mt-4 block bg-gradient-to-r from-cyan-300 via-blue-300 to-cyan-200 bg-clip-text text-transparent'>
            <ruby>現実<rt>リアル</rt></ruby>と<ruby>幻想<rt>ファンタジー</rt></ruby>、二つの<ruby>記録<rt>アーカイブ</rt></ruby>
          </span>
        </h1>

        <div class='mt-16 max-w-3xl space-y-3 text-lg leading-relaxed text-slate-300 md:text-xl'>
          <p class='font-jp-serif'>
            <span class='text-cyan-300'>技術記録</span>と<span class='text-fuchsia-300'>物語世界</span>を行き来する者
          </p>
          <p>
            在 <span class='font-readable-mono text-cyan-300'>code archives</span> 与 <span class='font-fiction text-fuchsia-300'>fictional worlds</span> 之间往返。
          </p>
        </div>

        <div class='mt-14 flex flex-wrap items-center justify-center gap-5'>
          <a
            href='/zh-cn/real/'
            class='rounded-full bg-gradient-to-r from-cyan-500 to-blue-600 px-8 py-4 text-sm font-black text-white shadow-lg shadow-cyan-500/25 transition hover:shadow-cyan-500/40'
            >进入现实侧</a
          >
          <a
            href='/zh-cn/fiction/'
            class='rounded-full border-2 border-fuchsia-400/50 px-8 py-4 text-sm font-black text-fuchsia-200 transition hover:border-fuchsia-400 hover:bg-fuchsia-500/20'
            >进入幻想侧</a
          >
          <a
            href={Profile.github}
            class='rounded-full border border-white/15 px-6 py-3 text-sm font-bold text-slate-400 transition hover:border-white/30 hover:text-white'
            >GitHub</a
          >
        </div>
      </div>
      <style>
        .hero-title-ruby rt {
          color: rgb(226 232 240 / 0.68);
          font-size: 0.28em;
          font-weight: 700;
          letter-spacing: 0.08em;
          line-height: 1;
          -webkit-text-fill-color: rgb(226 232 240 / 0.68);
        }
      </style>
    </section>

    <section class='mx-auto max-w-7xl px-5 py-24 lg:px-8'>
      <div class='grid gap-12 lg:grid-cols-[1fr_360px]'>
        <div>
          <p
            class='mb-6 text-sm font-black uppercase tracking-[0.28em] md:text-base text-cyan-300'
          >
            About me
          </p>
          <h2
            class='text-4xl font-black leading-tight tracking-[-0.04em] text-white md:text-5xl'
          >
            {Profile.name}
          </h2>
          <p class='mt-6 max-w-2xl text-lg leading-relaxed text-slate-400'>
            {Profile.tagline}。现居 {Profile.location}，目前就读于 {Profile.school}。
          </p>
          <div class='mt-8 flex flex-wrap gap-3'>
            <a
              href={Profile.github}
              class='rounded-full border border-white/10 px-5 py-2 text-sm font-bold text-white transition hover:bg-white/10'
              >GitHub</a
            >
            <a
              href={Profile.bilibili}
              class='rounded-full border border-white/10 px-5 py-2 text-sm font-bold text-white transition hover:bg-white/10'
              >Bilibili</a
            >
          </div>
          <div class='mt-8 flex flex-wrap gap-2'>
            {
              Profile.techStack.map((tech) => (
                <span class='rounded-full border border-white/10 px-3 py-1 text-xs font-bold text-slate-300'>
                  {tech}
                </span>
              ))
            }
          </div>
        </div>
        <div class='flex items-start justify-center lg:justify-end'>
          <div class='relative'>
            <div
              class='absolute -inset-4 rounded-3xl bg-gradient-to-br from-cyan-400/20 via-fuchsia-400/15 to-transparent blur-xl'
            >
            </div>
            <img
              src={Profile.avatar}
              alt={`${Profile.name} avatar`}
              class='relative h-48 w-48 rounded-3xl border border-white/10 shadow-2xl shadow-black/40'
            />
          </div>
        </div>
      </div>
    </section>

    <section
      class='mx-auto grid max-w-7xl gap-5 px-5 pb-28 lg:grid-cols-2 lg:px-8'
    >
      <a
        href='/zh-cn/real/'
        class='group relative overflow-hidden rounded-3xl border border-cyan-500/20 bg-gradient-to-br from-slate-900 to-slate-950 p-8 font-readable-mono shadow-2xl shadow-cyan-950/30 transition hover:-translate-y-1 hover:border-cyan-400/40 md:p-12'
      >
        <div
          class='pointer-events-none absolute -right-16 -top-16 h-56 w-56 rounded-full bg-cyan-500/10 blur-3xl'
        >
        </div>
        <p
          class='mb-6 text-sm font-black uppercase tracking-[0.24em] md:text-base text-cyan-400'
        >
          A / Real side
        </p>
        <h2
          class='text-4xl font-black leading-tight tracking-[-0.04em] text-white md:text-5xl'
        >
          项目、简历与学习笔记
        </h2>
        <p class='mt-6 max-w-xl text-lg leading-relaxed text-slate-400'>
          面向现实世界的区域，用于整理简历、项目、学习记录与博客文章。
        </p>
        <div class='mt-8 flex flex-wrap gap-2'>
          {
            ['简历', '项目', '笔记', '博客'].map((tag) => (
              <span class='rounded-full border border-cyan-500/30 px-3 py-1 text-xs font-bold text-cyan-300'>
                {tag}
              </span>
            ))
          }
        </div>
      </a>

      <a
        href='/zh-cn/fiction/'
        class='group relative overflow-hidden rounded-3xl border border-fuchsia-500/20 bg-gradient-to-br from-purple-950 to-slate-950 p-8 shadow-2xl shadow-fuchsia-950/30 transition hover:-translate-y-1 hover:border-fuchsia-400/40 md:p-12'
      >
        <div
          class='pointer-events-none absolute -right-16 -top-16 h-56 w-56 rounded-full bg-fuchsia-500/10 blur-3xl'
        >
        </div>
        <p
          class='mb-6 text-sm font-black uppercase tracking-[0.24em] md:text-base text-fuchsia-400'
        >
          B / Fiction side
        </p>
        <h2
          class='font-fiction text-4xl font-black leading-tight tracking-[-0.04em] text-white md:text-5xl'
        >
          角色、世界观与故事档案
        </h2>
        <p class='mt-6 max-w-xl text-lg leading-relaxed text-slate-400'>
          存放原创角色、世界观设定、故事章节与委托图像的创作档案。
        </p>
        <div class='mt-8 flex flex-wrap gap-2'>
          {
            ['OC', '世界观', '故事', '画廊'].map((tag) => (
              <span class='rounded-full border border-fuchsia-500/30 px-3 py-1 text-xs font-bold text-fuchsia-300'>
                {tag}
              </span>
            ))
          }
        </div>
      </a>
    </section>
  </main>
</Base>
