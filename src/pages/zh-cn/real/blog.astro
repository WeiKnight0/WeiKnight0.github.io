---
import { getCollection } from 'astro:content';

import RealPage from '@/templates/RealPage.astro';

const posts = (await getCollection('blog'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const dateFormatter = new Intl.DateTimeFormat('zh-CN', {
  dateStyle: 'medium',
});
const getPostDescription = (post: (typeof posts)[number]) =>
  post.data.description ?? post.data.title;
---

<RealPage
  title='博客 | 个人主页'
  description='博客文章与长期记录。'
  locale='zh-cn'
>
  <section class='mx-auto max-w-[92rem] px-4 py-24 sm:px-6 lg:px-8'>
    <p
      class='mb-6 text-base font-black uppercase tracking-[0.28em] text-cyan-300 md:text-lg'
    >
      Blog
    </p>
    <h1
      class='text-4xl font-black leading-none tracking-[-0.05em] text-white md:text-6xl'
    >
      博客
    </h1>
    <a
      href='/zh-cn/real/blog/tags/'
      class='mt-6 inline-flex rounded-full border border-cyan-300/20 px-4 py-2 text-base font-bold text-cyan-200 transition hover:bg-cyan-300/10'
      >浏览标签</a
    >
    <div class='mt-14 grid gap-5 md:grid-cols-3'>
      {posts.map((post) => (
        <a
          href={`/zh-cn/real/blog/${post.slug}/`}
          class="rounded-3xl border border-white/10 bg-white/[0.04] p-7 transition hover:border-cyan-300/40 hover:bg-white/[0.07]"
        >
          <p class="text-base font-bold text-cyan-300">
            {dateFormatter.format(post.data.date)}
          </p>
          <h2 class="mt-3 text-2xl font-black leading-tight text-white">
            {post.data.title}
          </h2>
          <p class="mt-4 text-base leading-7 text-slate-300">{getPostDescription(post)}</p>
          {post.data.tags.length > 0 && (
            <div class="mt-6 flex flex-wrap gap-2">
              {post.data.tags.map((tag) => (
                <span class="rounded-full border border-cyan-300/20 px-3 py-1 text-sm font-bold text-cyan-200">
                  {tag}
                </span>
              ))}
            </div>
          )}
        </a>
      ))}
    </div>
  </section>
</RealPage>
