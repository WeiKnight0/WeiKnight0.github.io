---
import { getCollection } from 'astro:content';

import RealPage from '@/templates/RealPage.astro';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
---

<RealPage
  title='博客 | 个人主页'
  description='博客文章与长期记录。'
  locale='zh-cn'
>
  <section class='mx-auto max-w-7xl px-5 py-24 lg:px-8'>
    <p
      class='mb-6 text-xs font-black uppercase tracking-[0.35em] text-cyan-300'
    >
      Blog
    </p>
    <h1
      class='text-6xl font-black leading-none tracking-[-0.08em] text-white md:text-8xl'
    >
      博客
    </h1>
    <div class='mt-14 grid gap-5 md:grid-cols-3'>
      {posts.map((post) => (
        <article class="rounded-3xl border border-white/10 bg-white/[0.04] p-7">
          <h2 class="text-2xl font-black text-white">{post.data.title}</h2>
          <p class="mt-4 leading-7 text-slate-400">{post.data.description}</p>
        </article>
      ))}
    </div>
  </section>
</RealPage>
