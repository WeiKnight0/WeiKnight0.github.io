---
import { getCollection } from 'astro:content';

import RealPage from '@/templates/RealPage.astro';

export async function getStaticPaths() {
  const notes = await getCollection('notes');

  return notes.map((note) => ({
    params: { slug: note.slug },
    props: { note },
  }));
}

const { note } = Astro.props;
const { Content } = await note.render();
const dateFormatter = new Intl.DateTimeFormat('zh-CN', {
  dateStyle: 'long',
});
---

<RealPage
  title={`${note.data.title} | 笔记 | 个人主页`}
  description={note.data.description}
  locale='zh-cn'
>
  <article class='mx-auto max-w-4xl px-5 py-24 lg:px-8'>
    <a
      href='/zh-cn/real/notes/'
      class='text-sm font-bold text-cyan-300 transition hover:text-cyan-200'
      >← 返回笔记</a
    >
    <p
      class='mt-10 text-sm font-black uppercase tracking-[0.28em] md:text-base text-cyan-300'
    >
      Note
    </p>
    <h1
      class='mt-6 text-5xl font-black leading-none tracking-[-0.06em] text-white md:text-7xl'
    >
      {note.data.title}
    </h1>
    <p class='mt-6 text-lg leading-8 text-slate-400'>
      {note.data.description}
    </p>
    <div class='mt-8 flex flex-wrap items-center gap-3 text-sm text-slate-500'>
      <time datetime={note.data.date.toISOString()}>
        {dateFormatter.format(note.data.date)}
      </time>
      {note.data.tags.map((tag) => (
        <span class='rounded-full border border-white/10 px-3 py-1 text-xs font-bold text-slate-300'>
          {tag}
        </span>
      ))}
    </div>
    <div class='prose prose-invert prose-slate mt-14 max-w-none prose-headings:font-black prose-a:text-cyan-300 prose-strong:text-white'>
      <Content />
    </div>
  </article>
</RealPage>
