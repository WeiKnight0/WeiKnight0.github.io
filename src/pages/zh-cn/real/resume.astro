---
import RealPage from '@/templates/RealPage.astro';

const sections = ['个人资料', '技能', '教育 / 经历', '亮点'];
---

<RealPage
  title='简历 | 个人主页'
  description='简历、技能、经历与联系方式。'
  locale='zh-cn'
>
  <section class='mx-auto max-w-7xl px-5 py-24 lg:px-8'>
    <p
      class='mb-6 text-xs font-black uppercase tracking-[0.35em] text-cyan-300'
    >
      Resume
    </p>
    <h1
      class='text-6xl font-black leading-none tracking-[-0.08em] text-white md:text-8xl'
    >
      简历
    </h1>
    <p class='mt-6 max-w-3xl text-lg leading-8 text-slate-400'>
      这里是简历页面的骨架。后续会替换为真实的教育经历、实践经历、技能栈、项目与联系方式。
    </p>
    <div class='mt-14 grid gap-5 md:grid-cols-2'>
      {sections.map((item) => (
        <article class="rounded-3xl border border-white/10 bg-white/[0.04] p-7">
          <h2 class="text-2xl font-black text-white">{item}</h2>
          <p class="mt-4 leading-7 text-slate-400">
            等待填充真实内容。
          </p>
        </article>
      ))}
    </div>
  </section>
</RealPage>
