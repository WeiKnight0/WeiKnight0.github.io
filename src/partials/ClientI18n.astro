  const storageKey = 'site-locale';
  const clientPaths = new Set(Object.keys(siteI18n.en.pages));
  const normalizePath = (path) => {
    const pathOnly = path.split(/[?#]/)[0] || '/';
    const withLeadingSlash = pathOnly.startsWith('/')
      ? pathOnly
      : `/${pathOnly}`;
    return withLeadingSlash.endsWith('/')
      ? withLeadingSlash
      : `${withLeadingSlash}/`;
  };
  const getPageConfig = (locale) =>
    siteI18n[locale]?.pages[normalizePath(window.location.pathname)];
  const getStoredLocale = () => {
    const storedLocale = localStorage.getItem(storageKey);
    return storedLocale === 'zh-cn' ? 'zh-cn' : 'en';
  };
  const renderTags = (element, tags) => {
    element.replaceChildren(
      ...tags.split(',').map((tag) => {
        const item = document.createElement('span');
        item.className = element.dataset.tagClass || '';
        item.textContent = tag;
        return item;
      })
    );
  };
  const renderChapterPrefix = (element, value) => {
    const order = element.getAttribute('data-page-i18n-order');
    element.textContent =
      value === '第' ? `${value} ${order} 章` : `${value} ${order}`;
  };
  const setHrefPrefix = (element, prefix) => {
    const slug = element.getAttribute('data-page-href-slug') || '';
    element.setAttribute('href', `${prefix}${slug}`);
  };
  const applyLocale = (locale) => {
    const dictionary = siteI18n[locale];
    const page = getPageConfig(locale);
    if (!dictionary || !page) return;

    document.documentElement.lang = dictionary.htmlLang;
    document.title = page.title;

    const description = document.querySelector('meta[name="description"]');
    if (description) description.setAttribute('content', page.description);

    document
      .querySelectorAll('[data-home-i18n], [data-page-i18n]')
      .forEach((element) => {
        const key =
          element.getAttribute('data-page-i18n') ||
          element.getAttribute('data-home-i18n');
        const value =
          page.text[key] || dictionary.nav[key?.replace('nav.', '')];
        if (!key || !value) return;

        if (
          element.hasAttribute('data-page-i18n-html') ||
          element.hasAttribute('data-home-i18n-html')
        ) {
          element.innerHTML = value;
          return;
        }

        if (
          element.hasAttribute('data-page-i18n-tags') ||
          element.hasAttribute('data-home-i18n-tags')
        ) {
          renderTags(element, value);
          return;
        }

        if (element.hasAttribute('data-page-i18n-order')) {
          renderChapterPrefix(element, value);
          return;
        }

        element.textContent = value;
      });

    document.querySelectorAll('[data-footer-i18n]').forEach((element) => {
      const key = element.getAttribute('data-footer-i18n');
      const value = dictionary.footer[key];
      if (value) element.textContent = value;
    });

    document
      .querySelectorAll('[data-home-link], [data-page-href]')
      .forEach((element) => {
        const key =
          element.getAttribute('data-page-href') ||
          element.getAttribute('data-home-link');
        const href = page.links[key];
        if (href) element.setAttribute('href', href);
      });

    document.querySelectorAll('[data-page-href-prefix]').forEach((element) => {
      const key = element.getAttribute('data-page-href-prefix');
      const href = page.links[key];
      if (href) setHrefPrefix(element, href);
    });

    document.querySelectorAll('[data-language-link]').forEach((element) => {
      const targetLocale = element.getAttribute('data-target-locale');
      if (targetLocale === locale) {
        element.setAttribute('aria-current', 'page');
        return;
      }
      element.removeAttribute('aria-current');
    });
  };
  const setupClientI18n = () => {
    const pathname = normalizePath(window.location.pathname);
    if (!clientPaths.has(pathname)) return;

    applyLocale(getStoredLocale());

    document.querySelectorAll('[data-language-link]').forEach((link) => {
      if (link.dataset.clientI18nReady === 'true') return;
      link.dataset.clientI18nReady = 'true';
      link.addEventListener('click', (event) => {
        if (!clientPaths.has(normalizePath(window.location.pathname))) return;

        const targetLocale = link.getAttribute('data-target-locale');
        if (!targetLocale || !siteI18n[targetLocale]) return;

        event.preventDefault();
        localStorage.setItem(storageKey, targetLocale);
        applyLocale(targetLocale);
      });
    });
  };

  setupClientI18n();
  document.addEventListener('astro:page-load', setupClientI18n);
</script>
