---
import { Profile } from '@/utils/Profile';
import { defaultLocale, type Locale } from '@/utils/i18n';

export interface Props {
  title: string;
  description?: string;
  date: Date;
  tags?: string[];
  lang?: string;
  locale?: Locale;
  backHref?: string;
  backLabel?: string;
  showBackLink?: boolean;
}

const {
  title,
  description = 'Study notes.',
  date,
  tags = [],
  lang,
  locale = defaultLocale,
  backHref = '/real/notes/',
  backLabel = 'Return to Notes',
  showBackLink = true,
} = Astro.props as Props;

const dateFormatter = new Intl.DateTimeFormat(locale === 'zh-cn' ? 'zh-CN' : 'en', {
  dateStyle: 'long',
});

const languageLabel =
  lang === 'en'
    ? 'Language: English'
    : lang === 'zh-cn'
      ? 'Language: 简体中文'
      : lang === 'zh-tw'
        ? 'Language: 繁體中文'
        : lang === 'zh-hk'
          ? 'Language: 繁體中文(香港)'
           : 'Language: Other Language';

const homeHref = locale === 'zh-cn' ? '/zh-cn/' : '/';
const homeLabel = 'Return to HomePage';
const realHref = locale === 'zh-cn' ? '/zh-cn/real/' : '/real/';
const realLabel = 'Return to Real';
---

<html lang={locale === 'zh-cn' ? 'zh-CN' : 'en'}>
  <head>
    <meta charset='UTF-8' />
    <meta name='viewport' content='width=device-width, initial-scale=1.0' />
    <title>{title} | Notes | My Homepage</title>
    <meta name='description' content={description} />
    <link rel='icon' href='/favicon.ico' />
    <link
      rel='stylesheet'
      href='https://fonts.googleapis.com/css2?family=Noto+Sans+SC:wght@400;500;700&family=Roboto:wght@400;500;700&display=swap'
    />
    <link
      rel='stylesheet'
      href='https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css'
    />
    <link
      rel='stylesheet'
      href='https://cdn.jsdelivr.net/npm/katex@0.16.45/dist/katex.min.css'
    />
    <link rel='stylesheet' href='/css/note.css' />
  </head>
  <body>
    <header class='navbar'>
      <div class='navbar-container'>
        <div class='navbar-brand'>
          <a class='avatar-link' href='https://github.com/WeiKnight0'>
            <img class='avatar' src={Profile.avatar} alt='WeiKnight' />
          </a>
          <div class='navbar-info'>
            <a class='name' href='https://github.com/WeiKnight0'>WeiKnight</a>
            <div class='subject'>Study Notes</div>
          </div>
          <a class='brand-home-link' href={homeHref}>
            <i class='fas fa-home'></i>
            <span>{homeLabel}</span>
          </a>
        </div>
        <nav class='navbar-actions' aria-label='Notes navigation'>
          {showBackLink && (
            <a class='nav-link' href={backHref} title={backLabel}>
              <i class='fas fa-level-up-alt'></i>
              <span>{backLabel}</span>
            </a>
          )}
          <a class='nav-link' href={realHref}>
            <i class='fas fa-compass'></i>
            <span>{realLabel}</span>
          </a>
        </nav>
      </div>
    </header>

    <section class='title-section'>
      <div class='title-container'>
        <h1 class='chapter-title'>{title}</h1>
        <div class='chapter-meta'>
          <span class='chapter-date'>
            <i class='far fa-calendar-alt'></i>
            <time datetime={date.toISOString()}>{dateFormatter.format(date)}</time>
          </span>
          <span class='chapter-lang'>{languageLabel}</span>
          {tags.length > 0 && (
            <div class='chapter-tags'>
              {tags.map((tag) => <span class='tag'>{tag}</span>)}
            </div>
          )}
        </div>
      </div>
    </section>

    <main class='content-section'>
      <article class='chapter-content'>
        <div class='note-body'>
        <slot />
        </div>
      </article>
      <div class='note-tools'>
        <button class='tool-btn' id='toggle-dark' type='button'>
          <i class='fas fa-moon'></i>
          <span>Dark Mode</span>
        </button>
        <button class='tool-btn' id='print-note' type='button'>
          <i class='fas fa-print'></i>
          <span>Print This Note</span>
        </button>
      </div>
    </main>

    <footer class='footer'>
      <div class='footer-content'>
        <p>© 2025 WeiKnight. All Rights Reserved.</p>
        <div class='footer-links'>
          <a href={`${locale === 'zh-cn' ? '/zh-cn' : ''}/real/notes/about/`} target='_blank'>About</a>
          <a href={`${locale === 'zh-cn' ? '/zh-cn' : ''}/real/notes/terms/`} target='_blank'>Terms of Use</a>
          <a href={`${locale === 'zh-cn' ? '/zh-cn' : ''}/real/notes/privacy/`} target='_blank'>Privacy Policy</a>
        </div>
      </div>
    </footer>

    <script src='/js/note.js' is:inline></script>
  </body>
</html>
