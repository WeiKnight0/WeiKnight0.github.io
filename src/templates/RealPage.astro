---
import Base from './Base.astro';
import { defaultLocale, type Locale } from '@/utils/i18n';

export interface Props {
  title: string;
  description: string;
  locale?: Locale;
}

const { title, description, locale = defaultLocale } = Astro.props as Props;
---

<Base head={{ title, description }} theme='real' locale={locale}>
  <main class='relative min-h-screen overflow-hidden bg-real-bg font-real-mono text-real-text selection:bg-real-accent/30 selection:text-real-text'>
    <div class='pointer-events-none fixed inset-0 z-0'>
      <div class='absolute inset-0 opacity-[0.18] [background-image:linear-gradient(rgba(0,245,255,0.18)_1px,transparent_1px),linear-gradient(90deg,rgba(0,245,255,0.16)_1px,transparent_1px)] [background-size:36px_36px]'></div>
      <div class='absolute inset-x-0 top-0 h-64 bg-gradient-to-b from-real-accent/15 to-transparent'></div>
      <div class='absolute -left-40 top-24 h-[32rem] w-[32rem] rounded-full bg-real-accent/10 blur-[120px]'></div>
      <div class='absolute -right-52 bottom-20 h-[38rem] w-[38rem] rounded-full bg-real-accentSecondary/10 blur-[150px]'></div>
    </div>
    <div class='relative z-10'>
      <slot></slot>
    </div>
  </main>
</Base>
